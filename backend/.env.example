# ─────────────────────────────────────────────────────────────
# SmartQueue RS — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# REQUIRED: Change this to a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# Database URL
# SQLite (default, single-server):
DATABASE_URL=sqlite:///./smartqueue.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/smartqueue

# Environment: development | production
ENVIRONMENT=development

# Token expiry in minutes (default: 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS: comma-separated list of allowed origins
# Development:
ALLOWED_ORIGINS=http://localhost:5176,http://localhost:5173,http://localhost:8080
# Production example:
# ALLOWED_ORIGINS=https://admin.yourhospital.com,https://app.yourhospital.com

# Firebase Cloud Messaging (optional — for push notifications)
FIREBASE_SERVER_KEY=

# WhatsApp notification (optional)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
